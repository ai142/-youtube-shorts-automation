# YouTube Shorts Automation Tool - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED API KEYS
# ===========================================

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key-here

# YouTube OAuth Credentials (get from https://console.cloud.google.com/)
# 1. Create project in Google Cloud Console
# 2. Enable YouTube Data API v3
# 3. Create OAuth 2.0 credentials
YOUTUBE_CLIENT_ID=your-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-client-secret

# ===========================================
# OPTIONAL API KEYS
# ===========================================

# Leonardo.ai for thumbnail generation (get from https://leonardo.ai/)
LEONARDO_API_KEY=your-leonardo-api-key

# ===========================================
# NOTIFICATION SETTINGS (OPTIONAL)
# ===========================================

# Discord/Slack webhook for failure notifications
WEBHOOK_URL=

# Email notifications
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TO=

# ===========================================
# RENDER.COM SETTINGS (Auto-configured)
# ===========================================

# Set to "true" when deployed on Render.com
RENDER=false
